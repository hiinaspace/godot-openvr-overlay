{
  "controller_type": "knuckles",
  "description": "Default bindings for Valve Index Controllers",
  "name": "Godot OpenVR Overlay — Index Controller",
  "options": {},
  "simulated_actions": [],
  "bindings": {
    "/actions/main": {
      "sources": [
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull":  { "output": "/actions/main/in/left_trigger" },
            "click": { "output": "/actions/main/in/left_trigger_click" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull":  { "output": "/actions/main/in/right_trigger" },
            "click": { "output": "/actions/main/in/right_trigger_click" }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "force_sensor",
          "inputs": {
            "force": { "output": "/actions/main/in/left_grip" }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "force_sensor",
          "inputs": {
            "force": { "output": "/actions/main/in/right_grip" }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/left_grip_click" }
          },
          "parameters": {
            "force_input": "force",
            "click_activate_threshold": "0.7",
            "click_deactivate_threshold": "0.6",
            "haptic_amplitude": "0"
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/right_grip_click" }
          },
          "parameters": {
            "force_input": "force",
            "click_activate_threshold": "0.7",
            "click_deactivate_threshold": "0.6",
            "haptic_amplitude": "0"
          }
        },
        {
          "path": "/user/hand/left/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/main/in/left_thumbstick" },
            "click":    { "output": "/actions/main/in/left_thumbstick_click" }
          }
        },
        {
          "path": "/user/hand/right/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/main/in/right_thumbstick" },
            "click":    { "output": "/actions/main/in/right_thumbstick_click" }
          }
        },
        {
          "path": "/user/hand/left/input/trackpad",
          "mode": "trackpad",
          "inputs": {
            "position": { "output": "/actions/main/in/left_trackpad" }
          }
        },
        {
          "path": "/user/hand/right/input/trackpad",
          "mode": "trackpad",
          "inputs": {
            "position": { "output": "/actions/main/in/right_trackpad" }
          }
        },
        {
          "path": "/user/hand/left/input/trackpad",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/left_trackpad_click" }
          },
          "parameters": {
            "force_input": "force",
            "click_activate_threshold": "0.7",
            "click_deactivate_threshold": "0.6",
            "haptic_amplitude": "0"
          }
        },
        {
          "path": "/user/hand/right/input/trackpad",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/right_trackpad_click" }
          },
          "parameters": {
            "force_input": "force",
            "click_activate_threshold": "0.7",
            "click_deactivate_threshold": "0.6",
            "haptic_amplitude": "0"
          }
        },
        {
          "path": "/user/hand/left/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/left_a" }
          }
        },
        {
          "path": "/user/hand/right/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/right_a" }
          }
        },
        {
          "path": "/user/hand/left/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/left_b" }
          }
        },
        {
          "path": "/user/hand/right/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/right_b" }
          }
        },
        {
          "path": "/user/hand/left/input/system",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/left_system" }
          }
        },
        {
          "path": "/user/hand/right/input/system",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/right_system" }
          }
        }
      ]
    }
  }
}
